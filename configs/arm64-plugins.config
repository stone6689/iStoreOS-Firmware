# iStoreOS arm64 + Plugins Configuration
# Based on official iStoreOS arm64 build
# Added: luci-app-openclash + luci-app-passwall with all proxy cores

CONFIG_TARGET_armvirt=y
CONFIG_TARGET_armvirt_64=y
CONFIG_TARGET_armvirt_64_DEVICE_generic=y

# ── OpenClash ──────────────────────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-openclash=y

# ── PassWall LuCI app ──────────────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-passwall=y

# PassWall: enable iptables transparent proxy
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=y
# PassWall: enable nftables transparent proxy
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y

# ── PassWall proxy cores ───────────────────────────────────────────────────
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_hysteria=y
CONFIG_PACKAGE_naiveproxy=y
CONFIG_PACKAGE_shadowsocks-rust=y
CONFIG_PACKAGE_shadowsocksr-libev=y
CONFIG_PACKAGE_shadowsocks-libev=y
CONFIG_PACKAGE_tuic-client=y
CONFIG_PACKAGE_trojan-plus=y
CONFIG_PACKAGE_simple-obfs=y

# ── PassWall DNS & routing tools ───────────────────────────────────────────
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_geoview=y

# ── PassWall proxy plugins ─────────────────────────────────────────────────
CONFIG_PACKAGE_v2ray-plugin=y
CONFIG_PACKAGE_xray-plugin=y
CONFIG_PACKAGE_shadow-tls=y

# ── v2ray geodata ──────────────────────────────────────────────────────────
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# ── dnsmasq-full ───────────────────────────────────────────────────────────
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq=n
