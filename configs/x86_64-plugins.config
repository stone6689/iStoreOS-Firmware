# iStoreOS x86_64 + Plugins Configuration
# Based on official iStoreOS x86_64 build
# Added: luci-app-openclash + luci-app-passwall with all proxy cores

CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# ── OpenClash ──────────────────────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-openclash=y

# ── PassWall LuCI app ──────────────────────────────────────────────────────
CONFIG_PACKAGE_luci-app-passwall=y

# PassWall: enable iptables transparent proxy (default on non-firewall4 systems)
CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy=y
# PassWall: enable nftables transparent proxy (for firewall4 / nftables systems)
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y

# ── PassWall proxy cores (all from passwall_packages feed) ─────────────────
# Xray-core: primary proxy core (VMess, VLESS, Trojan, Shadowsocks, etc.)
CONFIG_PACKAGE_xray-core=y
# Sing-box: modern multi-protocol proxy core
CONFIG_PACKAGE_sing-box=y
# Hysteria2: high-performance UDP-based proxy
CONFIG_PACKAGE_hysteria=y
# NaiveProxy: anti-censorship proxy based on Chrome's network stack
CONFIG_PACKAGE_naiveproxy=y
# Shadowsocks-rust: Rust implementation of Shadowsocks
CONFIG_PACKAGE_shadowsocks-rust=y
# ShadowsocksR-libev: ShadowsocksR client
CONFIG_PACKAGE_shadowsocksr-libev=y
# Shadowsocks-libev: classic C implementation
CONFIG_PACKAGE_shadowsocks-libev=y
# TUIC: QUIC-based proxy protocol
CONFIG_PACKAGE_tuic-client=y
# Trojan-plus: Trojan with extra features
CONFIG_PACKAGE_trojan-plus=y
# simple-obfs: Shadowsocks obfuscation plugin
CONFIG_PACKAGE_simple-obfs=y

# ── PassWall DNS & routing tools ───────────────────────────────────────────
# ChinaDNS-NG: split DNS for China/overseas traffic
CONFIG_PACKAGE_chinadns-ng=y
# dns2socks: forward DNS queries over SOCKS5
CONFIG_PACKAGE_dns2socks=y
# tcping: TCP ping utility used by PassWall
CONFIG_PACKAGE_tcping=y
# ipt2socks: transparent proxy helper
CONFIG_PACKAGE_ipt2socks=y
# microsocks: lightweight SOCKS5 server
CONFIG_PACKAGE_microsocks=y
# Geoview: converts Geofile to rule sets (required for Sing-box routing since 1.12)
CONFIG_PACKAGE_geoview=y

# ── PassWall proxy plugins ─────────────────────────────────────────────────
# v2ray-plugin: Shadowsocks WebSocket plugin
CONFIG_PACKAGE_v2ray-plugin=y
# xray-plugin: Shadowsocks WebSocket/gRPC plugin
CONFIG_PACKAGE_xray-plugin=y
# shadow-tls: TLS obfuscation for Shadowsocks
CONFIG_PACKAGE_shadow-tls=y

# ── v2ray geodata (GeoIP / GeoSite rules used by Xray and PassWall) ────────
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y

# ── dnsmasq-full: required by PassWall for DNS filtering ──────────────────
# Replaces dnsmasq; must be selected explicitly to avoid conflicts
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_dnsmasq=n
